<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The app's only cryptography is HTTPS to the Scripty API, which is exempt
	     from export regulations. Saying so here means a TestFlight upload does
	     not stop and wait for someone to answer that question by hand. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- scripty://demo launches the offline demo (e.g. from a Shortcut). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>scripty.scripty</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>scripty</string>
			</array>
		</dict>
	</array>

	<!-- Payload for dragging a script element onto another to reorder it.
	     Declared so a drop only accepts elements dragged from this app; a
	     plain-text type would let any dragged text land on the script. -->
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>scripty.scripty.block</string>
			<key>UTTypeDescription</key>
			<string>Script Element</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
