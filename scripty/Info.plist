	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>scripty.scripty</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>scripty</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
